			"simulatorBuild": true,
			"problemMatcher": [
				"$monkeyc.error",
				"$monkeyc.fileWarning",
				"$monkeyc.genericWarning"
			],
			"label": "monkeyc: fenix7",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "omonkeyc",
			"device": "fenix7",
