				"$monkeyc.genericWarning"
			],
			"label": "monkeyc: fenix6pro",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "monkeyc",
			"device": "fenix5plus",
			"simulatorBuild": true,
			"problemMatcher": [
				"$monkeyc.error",
				"$monkeyc.fileWarning",
				"$monkeyc.genericWarning"
			],
			"label": "monkeyc: fenix5plus",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
